# Database
POSTGRES_DB=atlas
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=change-me-strong-password

# Backend
SECRET_KEY=change-me-to-very-long-random-secret-key-in-production
MAX_FILE_SIZE_MB=100
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Единый пароль для входа в систему (простая защита без ролей)
ADMIN_PASSWORD=change-me-strong-password
# true, если система работает по HTTPS
COOKIE_SECURE=false

# Frontend
VITE_API_URL=http://localhost:8000

# PgAdmin (optional, run with --profile tools)
PGADMIN_EMAIL=admin@atlas.local
PGADMIN_PASSWORD=change-me
